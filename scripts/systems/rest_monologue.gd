class_name RestMonologue extends RefCounted

static func get_monologue(character_id: StringName) -> String:
	match character_id:
		&"cultist":
			return _cultist_monologue()
		&"ex_raider":
			return _ex_raider_monologue()
		&"wanderer":
			return _wanderer_monologue()
		&"beast_master":
			return _beast_master_monologue()
		&"hedonist":
			return _hedonist_monologue()
		&"conqueror":
			return _conqueror_monologue()
	return ""


static func _cultist_monologue() -> String:
	var band: StringName = GameManager.get_faith_band()
	var lines: Array[String] = []
	match band:
		&"zealot":
			lines = [
				"炎が揺れる。スピード・デーモンの吐息だ。アータルはペンダントに口づけし、瞳を閉じた。「……加速せよ。止まることなかれ」",
				"薪が爆ぜるたび、V8の聖火が天へ昇る。アータルは両手を組み、唇が祈りの韻律を刻んだ。明日もハイウェイは続く。",
				"「焚火は小さなエンジンだ」——誰に言うともなく呟き、アータルは炎に薪をくべた。スピード・デーモンの教えは正しい。止まらなければ、死なない。",
				"星が回る。車輪のように。世界そのものがエンジンだ。アータルはペンダントを握り、唇の端を持ち上げた。信じているのではない。知っているのだ。",
			]
		&"devout":
			lines = [
				"ペンダントを握る手に、迷いが混じる。「……加速は……正しい、はず」。炎を見つめる目に、問いが浮かんでは消えた。",
				"焚火の前で祈ろうとした。言葉が途中で止まる。スピード・デーモンの教えが、喉に引っかかる感触。「……なぜ、こんなに重い」",
				"薪をくべる手が一瞬止まった。聖典の一節が頭をよぎったが、続きが思い出せない。以前なら息をするように出てきたのに。",
			]
		&"doubting":
			lines = [
				"炎を見つめる。ただの炎だ。スピード・デーモンの吐息でも、聖火でもない。ただの、燃える木。……いつからそう見えるようになった？",
				"ペンダントに触れかけて、やめた。指先が金属に触れる直前で、腕が止まる。祈る理由が、見つからない。",
				"「……わからない。前はわかっていたのに」。焚火の前で膝を抱え、アータルは黙り込んだ。",
			]
		&"apostate":
			lines = [
				"…………。焚火が燃えている。暖かい。それだけだ。",
				"ペンダントは首にかかったまま。外す理由もない。つける理由もない。アータルは火を見つめた。何も祈らなかった。",
				"薪をくべた。火が大きくなった。……おはよう。いや、まだ夜か。",
			]
	if lines.is_empty():
		return ""
	return lines[randi() % lines.size()]


static func _ex_raider_monologue() -> String:
	var heat: int = CombatManager.player_heat
	var lines: Array[String] = []
	if heat >= 70:
		lines = [
			"焚火の前で座っていられない。脚が跳ねる。拳を開いて、閉じて、また開く。「……ちっ、寝れるわけねぇだろ」",
			"革ジャンの襟を掴んで引き下ろす。首筋に夜風が当たる。冷たい。足りない。全然足りない。ワスプは焚火を蹴りそうになって、寸前で止めた。",
			"歯を噛み締めると、こめかみに血管が浮く。殴りたい。何を？　何でもいい。この熱を吐き出す先がない。",
		]
	elif heat >= 40:
		lines = [
			"革ジャンの内ポケットからナイフを出し、刃を確認する。研ぐ必要はない。だが手を動かしていないと落ち着かない。",
			"焚火の向こう側に誰もいないことを確認してから、ワスプは息を吐いた。背中を見せても大丈夫。たぶん。",
			"「……あたしがこんなとこで焚火なんてね」。コカトリスにいた頃は、火を囲むのは作戦会議の前だけだった。",
		]
	else:
		lines = [
			"焚火の傍で、膝を抱える。ナイフは手の届く場所。それだけ確認すれば、少しだけ肩の力が抜けた。",
			"炎を眺めていると、時々、昔の焚火と重なる。コカトリスの野営地。あの匂いだけは同じだ。ガソリンと、砂と、血の鉄臭さ。",
			"星が綺麗だ、なんて柄じゃない。でも空は広い。壁の中にいた10年間、こんな空は見えなかった。",
		]
	return lines[randi() % lines.size()]


static func _wanderer_monologue() -> String:
	var has_dog: bool = GameManager.current_companion != null and GameManager.current_companion.companion_type == CompanionData.CompanionType.DOG
	var lines: Array[String] = []
	if has_dog:
		lines = [
			"「いい夜だな、パートナー」。犬の耳がぴくりと動く。ウェズリーは止まった腕時計に目を落とし、また火に視線を戻した。",
			"犬が膝の上に顎を乗せてきた。重い。温かい。ウェズリーはその頭を撫でながら、小さく笑った。「……行くぞ、明日も」",
			"「嘘みたいだろ」。犬に語りかける。「30年前はな、こんな道路にも番号がついてた。標識があって、行き先が書いてあった」。犬は尻尾を振った。聞いていないだろう。それでいい。",
		]
	else:
		lines = [
			"焚火に薪をくべる。止まった腕時計の文字盤が、炎を映して光った。何時だ？　知る術はない。もう30年、この時計は動いていない。",
			"一人は慣れている。慣れすぎている。それが問題だと気づいたのは、いつだったか。ウェズリーは帽子を深く被り直した。",
			"砂漠の夜は冷える。焚火の反対側に誰もいない。当たり前だ。30年間、大抵そうだった。……大抵。",
		]
	return lines[randi() % lines.size()]


static func _beast_master_monologue() -> String:
	var has_beast: bool = not CombatManager.player_beasts.is_empty()
	var lines: Array[String] = []
	if has_beast:
		lines = [
			"虎が焚火のそばで横たわっている。ミーシャはその背に手を置いた。心拍が掌に伝わる。規則的で、穏やかで、安全の証。",
			"虎の耳が風に反応して動く。ミーシャは同じ方向に目を向けた。何もいない。虎が鼻を鳴らす。「……うん、大丈夫」",
			"虎の腹に頬を寄せる。毛皮越しに聞こえる呼吸の音。檻の中で初めてこの音を聞いた夜を、まだ覚えている。あの時は二頭とも、壊れていた。",
		]
	else:
		lines = [
			"焚火の傍に、虎がいない。ミーシャは膝を抱え、火を見つめた。暖かい。でも、足りない。",
			"（……静かすぎる）。ミーシャは地面に手を置いた。振動を感じ取ろうとする。獣の足音を探す癖が、もう身体に染みついている。",
			"夜風が吹く。砂の匂い。獣の匂いはしない。ミーシャは毛布を引き寄せ、小さく丸まった。",
		]
	return lines[randi() % lines.size()]


static func _hedonist_monologue() -> String:
	var euphoria: int = CombatManager.player_euphoria
	var lines: Array[String] = []
	if euphoria >= 75:
		lines = [
			"焚火の光がちらちら揺れるたび、指先がぴくぴく反応する。感覚が研ぎ澄まされすぎて、風が肌を撫でるだけで背筋がぞくっとした。「あは……♡ やば、今めっちゃキてる」",
			"ジュリエットの鞘のリボンを指で弄びながら、ホタルは夜空を見上げた。星がいつもより近い。肌が熱い。ネオンが巡っている。世界が綺麗に見える夜だ。「サイコー♡」",
			"焚火の温度が肌に滲み込む。指先が、足の裏が、耳の後ろが、全部繋がっている感じ。ホタルは自分の腕を撫でた。鳥肌。「……ウケる。焚火でこんなんなるとか♡」",
		]
	elif euphoria >= 33:
		lines = [
			"ロミオ（右）とロミオ（左）を膝の上に並べて、ホタルはグリップのネイルポリッシュを確認した。蛍光イエロー。まだ剥がれてない。「よしよし」",
			"焚火に手をかざす。温かい。うん、温かい。それだけ。ホタルは足を組み替えて、ネオンバイアルの残量を確認した。……まだある。よし。",
			"「ねー、火ってさ、ずっと見てると何か見えてこない？」。誰にともなく呟いてから、返事がないことに気づいた。「あ、そっか。一人か」",
		]
	else:
		lines = [
			"……寒い。焚火の前なのに。ホタルは膝を抱え、自分の腕を擦った。指先が震えている。ネオンが足りない。頭がぼんやりする。",
			"焚火の光を見つめる。綺麗だと思えない。何も思えない。ホタルはバイアルに手を伸ばしかけて、空であることを思い出した。「……大丈夫だよ」。声が平坦だった。",
			"ジュリエットを抱きしめるように膝の上に置く。冷たい鞘の感触。リボンのピンクが、火の光で赤黒く見える。……次の集落まで、あとどれくらい？",
		]
	return lines[randi() % lines.size()]


static func _conqueror_monologue() -> String:
	var lines: Array[String] = [
		"焚火の薪が爆ぜる音。夜風が砂を運ぶ音。遠くで何かが吠える声。覇者は目を閉じ、耳だけで世界を読んだ。",
		"炎の熱が左頬を焼く。右頬は夜気に冷える。その境界線の上に、覇者は座っている。首飾りの石が、胸の上で体温を吸っていた。",
		"肉を焼く匂い。脂が落ちて火が跳ねる。腹が鳴った。覇者は無言で肉をひっくり返した。焼き加減を見る目は真剣だ。",
		"砂の上に大の字になる。星が近い。手を伸ばせば届きそうだ。……届かない。当たり前だ。覇者は手を下ろし、首飾りを握った。",
		"風向きが変わった。砂嵐の前兆か。覇者は鼻を鳴らし、空気の湿り気を嗅いだ。まだ遠い。眠れる。",
	]
	return lines[randi() % lines.size()]
