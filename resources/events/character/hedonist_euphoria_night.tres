[gd_resource type="Resource" script_class="EventData" load_steps=6 format=3]

[ext_resource type="Script" path="res://scripts/data/event_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/event_choice_data.gd" id="2"]

[sub_resource type="Resource" id="choice_1"]
script = ExtResource("2")
label = "ネオンを一服してから身体を預ける"
requirement = "euphoria>=33"
result_text = "バイアルを傾け、蒸気を吸い込む。蛍光の青が喉の奥で弾け、壁越しの音楽が皮膚の下に入り込んできた。相手の指先が腕に触れただけで、背筋が跳ねる。「あは……♡ やば、今のだけでキたかも」\n\n男がホタルの胸を支える。重さで前に傾いたそれを揉まれた瞬間、薄く色づいた乳首の奥から痺れが腹まで落ちた。「そこ、雑にしたら噛むからね♡」。仕事の声を出したつもりなのに、語尾が勝手に甘くなる。10年分の手順で相手を誘導しながら、ホタル自身の身体だけが手順の外へ飛び出していく。\n\n奥まで届いた瞬間、音楽、汗、酒の匂い、胸の重さが全部同じ場所で鳴った。「待っ……ちょ、無理、止まんない……♡」。絶頂は一度で終わらない。男が果てる気配を読んで腰を沈めると、内側で熱が弾け、声が隣の部屋の笑い声を塗り潰した。\n\nしばらく動けなかった。胸の下に汗が溜まり、痩せた腹に指跡が残っている。男が「もう無理」と笑う。ホタルはバイアルの残りを舌先で確かめた。「えー、無理とか言うんだ」。二回目は短い。声は文章にならず、最後は相手の肩に歯を立てたまま達した。朝、名前も知らない寝顔の横で、ホタルは胸に残った手形を見下ろす。「今日は走れる」"
hp_change = 5
fuel_change = -1
euphoria_change = -20

[sub_resource type="Resource" id="choice_2"]
script = ExtResource("2")
label = "素面のまま相手をする"
requirement = ""
result_text = "ネオンを使わずに部屋へ上がった。相手の手が肌に触れる。温かい。それだけ。ホタルは笑い、重い胸を両手で持ち上げて見せる。「好きでしょ、こういうの」。男の視線はわかりやすく、扱いやすい。\n\n身体は正確に動いた。胸の重さと谷間の圧で呼吸を奪い、指先で速度を調整する。男が呻くたび、ホタルは必要なだけ笑い、必要なだけ声を出す。乳首を触られても、腰を引き寄せられても、感覚は薄い膜の向こう側にあった。\n\n相手が果てる瞬間、ホタルは息を合わせて背中を反らした。「あんっ……♡」。仕事としては満点。男は満足した顔で胸に頬を埋め、眠りかける。重い。汗で肌が冷える。\n\n相手の呼吸が深くなってから、ホタルは腕をほどいた。身体には痕跡がある。けれど何も残っていない。「……これがイクってことなんだっけ」。バイアルを振る。残りわずか。蓋を開けず、また閉めた。「大丈夫だよ」。声は平坦だった。"
hp_change = 3

[sub_resource type="Resource" id="choice_3"]
script = ExtResource("2")
label = "犬とバーのカウンターに残る"
requirement = "companion==dog"
result_text = "ロミオ（右）をカウンターに置き、蒸留酒をちびちびやる。足元で犬が丸くなっている。尻尾がたまに床を叩く。ネオンも男もいらない夜がある。あるらしい。自分でも驚いている。「ねー、あんたってさ、なんでいるの？」。犬は答えない。答えないまま、温かい。それだけで今夜は足りた。"
hp_change = 5
karma_change = 1

[sub_resource type="Resource" id="choice_4"]
script = ExtResource("2")
label = "ここでは何もしない"
requirement = ""
result_text = "カウンターで一杯だけ引っかけて、バーを出た。夜風が肌を撫でる。「つまんな」。呟いてみたけど、別につまらなくはなかった。"

[resource]
script = ExtResource("1")
id = &"hedonist_euphoria_night"
title = "灯りの落ちない部屋"
body_text = "集落の外れに、壁の薄いバーがある。ネオンサインの青白い光が入口を染めている。安い蒸留酒の匂い。音楽。笑い声。ホタルにとっては実家みたいなものだ。カウンターに座ると、隣の男が目を合わせてきた。悪くない顔。使えそうな身体。ロミオ（右）のグリップに触れてから——ああ、これは銃だった——指を離す。「ねー、上空いてんの？」。10年分の笑顔が、自動的に唇に浮かんだ。"
required_character = &"hedonist"
choices = [SubResource("choice_1"), SubResource("choice_2"), SubResource("choice_3"), SubResource("choice_4")]
