[gd_resource type="Resource" script_class="EventData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/data/event_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/event_choice_data.gd" id="2"]

[sub_resource type="Resource" id="choice_1"]
script = ExtResource("2")
label = "使えそうな男を物色する"
requirement = "heat>=50"
result_text = "三人目で目が止まった。壁際で一人飲んでいる男。肩幅はそこそこ、指が太い。翌朝に何も求めてこない程度には大人。ホーネットは革ジャンの前が開くように座る。「一人？」「今は」「あたしも」。それだけで十分だった。\n\n二階の部屋は狭く、壁越しの笑い声が酒の匂いに混ざっている。革ジャンを脱ぐと、男の視線が胸に落ちた。いつもの反応。ホーネットは口の端を上げ、わざとゆっくり胸を寄せる。「見すぎ」「見るだろ、そりゃ」「なら役に立てな」。重い乳房で男を包み、呼吸が荒くなったところで止める。「まだ」。主導権は渡さない。\n\n「入れて」。奥まで届いた瞬間、喉から息が漏れた。感じていないわけではない。感じている自分を観察する冷たい目が、まだ頭の奥にある。男の指がアームガードに触れると、腰が一瞬止まった。「そこ触んな」「悪い」「謝る暇あったら動け」。戦闘の残像が、身体の奥で少しずつ潰れていく。\n\n男の呼吸が崩れる。ホーネットは髪を掴んで顔を近づけた。「まだ出すな。あたしが先」。胸を掴まれ、乳房の重さが揺さぶられた瞬間、防壁の下で何かが切れた。「っ……くそ、そこで止めんな」。声を殺したまま達し、膝から力が抜ける前に男が果てる。\n\n男が寝息を立て始めた後、ホーネットは革ジャンを拾った。胸の下の汗を拭い、アームガードの位置を直す。鏡の中の自分は、いつも通りの顔をしている。カウンターで三杯目を頼む。グラスを持つ指先は、もう震えていなかった。"
hp_change = 3
heat_change = -25

[sub_resource type="Resource" id="choice_2"]
script = ExtResource("2")
label = "部屋を取って一人で寝る"
requirement = ""
result_text = "壁際の男と目が合い——逸らした。今夜はだめだ。知らない男の肌に触れる気力が湧かない。一番安い部屋の鍵を受け取り、二階へ上がる。\n\nベッドに横たわっても眠れない。瞼の裏で戦闘の残像がちらつく。「……ったく」。自分で始末をつけるしかない。胸を片手で押さえ、もう片方の手で身体の反応を探る。戦闘の後の身体は扱いやすい。少し強く触れれば、すぐ波が来る。\n\n一度目は早かった。二度目、三度目。乳房の重さが呼吸の邪魔をし、胸の下に汗が溜まる。四度目で膝が震え、五度目でようやく手が止まった。身体は何度でも応える。けれど男の体温がない。重さがない。覆いかぶさってくる息遣いがない。\n\nホーネットは革ジャンを抱きしめた。ガソリンと血の匂いが染みついた革を、汗ばんだ胸に押しつける。誰かの体温の代わりに。しばらくしてから、まだ熱が残っていることに気づいた。——やっぱ、あの男拾っときゃよかった。眠りは来ない。"
heat_change = 5
fuel_change = -2

[resource]
script = ExtResource("1")
id = &"ex_raider_heat_relief"
title = "熱の鎮め方"
body_text = "酒場の扉を開けた瞬間、安い蒸留酒とガソリンの混じった空気がホーネットの顔を撫でた。苛立ちがまだ腕に残っている。指先が震えるのは寒さじゃない——戦闘の余韻が身体の奥で燃え続けている。カウンターで蒸留酒を半分流し込む。喉が焼ける感覚が、ほんの一瞬だけ腹の底の炎を搔き消す。一瞬だけ。視線を感じる。革ジャンの下で押し潰されている胸元を隠すつもりはない。ジッパーは深く開いている。鎧の一部であり、武器の一部。指先がまだ震えている。このまま震えを抱えて眠るか。それとも——"
required_character = &"ex_raider"
choices = [SubResource("choice_1"), SubResource("choice_2")]
