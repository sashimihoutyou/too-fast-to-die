[gd_resource type="Resource" script_class="EventData" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/data/event_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/event_choice_data.gd" id="2"]

[sub_resource type="Resource" id="choice_1"]
script = ExtResource("2")
label = "使えそうな男を物色する"
requirement = "heat>=50"
result_text = "三人目で目が止まった。壁際の席、一人で飲んでいる男。肩幅はそこそこ、指が太い。馬鹿すぎず、賢すぎず。翌朝に何も求めてこない程度には大人。グラスを持って歩み寄り、革ジャンの前が開くように座る。「一人？」「今は」「あたしも」。それだけで十分だった。二杯目が空になる頃には男の手がヴェスパの太ももに触れていて、ヴェスパはその手をどかさなかった。二階の部屋は狭い。壁が薄い。隣室から笑い声が漏れる。革ジャンを脱ぎ、男の息を呑む音を聞き、胸を寄せた。手慣れた手順。先端を親指で軽く撫でてやり、リズムを変え、男の呼吸が上がったところで止める。「入れて」。挿入。喉からかすかに息が漏れる。感じていないわけではない。ただ、感じている自分を見つめるもう一人の自分が、冷静にそこにいる。身体の奥で戦闘の余韻が溶けていく。怒りが、苛立ちが、殺したいほどの衝動が、振動に少しずつ揉み消されていく。男が果てた後、寝息を待ってからヴェスパは革ジャンを拾い、階段を降りた。カウンターで三杯目を頼む。指先は、もう震えていなかった。"
hp_change = 3
heat_change = -25

[sub_resource type="Resource" id="choice_2"]
script = ExtResource("2")
label = "部屋を取って一人で寝る"
requirement = ""
result_text = "壁際の男と目が合い——逸らした。今夜はだめだ。知らない男の肌に触れる気力が湧かない。一番安い部屋の鍵を受け取り、二階へ。ベッドに横たわる。眠れない。瞼の裏で戦闘の残像がちらつく。手が腹を這い、下へ降りていく。「……ったく」。自分で始末をつけるしかない。だが終わらない。一度、二度と波が来ても腹の底の熱が抜けない。触れば触るほど昂り、速めれば速めるほど足りなくなる。四度目。五度目。身体は何度でも応えるが、男の体温がない。重さがない。覆いかぶさってくる他人の息遣いがない。指だけでは足りない。革ジャンを抱きしめていた。ガソリンと血の匂いが染みついた革を、汗ばんだ胸に押しつけている。誰かの体温の代わりに。——やっぱ、あの男拾っときゃよかった。寝返りを打つ。眠りは来ない。"
heat_change = 5
fuel_change = -2

[resource]
script = ExtResource("1")
id = &"ex_raider_heat_relief"
title = "熱の鎮め方"
body_text = "酒場の扉を開けた瞬間、安い蒸留酒とガソリンの混じった空気がヴェスパの顔を撫でた。苛立ちがまだ腕に残っている。指先が震えるのは寒さじゃない——戦闘の余韻が身体の奥で燃え続けている。カウンターで蒸留酒を半分流し込む。喉が焼ける感覚が、ほんの一瞬だけ腹の底の炎を搔き消す。一瞬だけ。視線を感じる。革ジャンの下で押し潰されている胸元を隠すつもりはない。ジッパーは深く開いている。鎧の一部であり、武器の一部。指先がまだ震えている。このまま震えを抱えて眠るか。それとも——"
required_character = &"ex_raider"
choices = [SubResource("choice_1"), SubResource("choice_2")]
