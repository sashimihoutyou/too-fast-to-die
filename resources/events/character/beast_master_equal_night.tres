[gd_resource type="Resource" script_class="EventData" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/data/event_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/event_choice_data.gd" id="2"]

[sub_resource type="Resource" id="choice_1"]
script = ExtResource("2")
label = "近づくのを許す"
requirement = ""
result_text = "椀を受け取り、口をつけた。薬草の苦みが舌に残る。男は焚火の反対側に座り直そうとする。だがミーシャは動かなかった。距離を詰めたのは、男ではなくミーシャの方だ。\n\n肩が触れる。びくりと退きかけた身体を、意志の力で押しとどめた。支配と従属の匂いを探す。見つからない。これは奴隷時代のそれとは違う——そう自分に言い聞かせた。\n\n男の手が頬に伸びる。触れる直前で止まった。「……嫌なら言えよ」。許可を待つその間が、ミーシャの警戒を静かに解いていく。声は出なかった。代わりに、小さく頷いた。\n\n指が頬に触れた瞬間、肩の力が抜けた。唇が重なる。虎の舌のざらつきとは違う柔らかさに、身体が戸惑った。これは何だ——快感という名前を、ミーシャはまだ持っていない。身体の奥が疼く。名前をつける前に、男の手が服の下へ滑り込んだ。\n\n肌に触れる指は性急でなかった。確かめるように動く。硬直していた背中が、少しずつほどけていく。「大丈夫か」。何度も聞かれ、何度も頷いた。答えを探す余裕はない。身体が先に応え、思考は遅れて追いついてくる。押し倒された拍子に、視界の端で虎が耳を動かした。起きてはいない。それでも、そこにいる。安全の証はまだ消えていなかった。\n\n体温が重なった瞬間、声を上げかけて飲み込んだ。飲み込む必要はなかったのかもしれない。それでも喉が覚えた癖は、簡単には抜けない。男の呼吸が乱れ、動きが速くなる。痛みはなかった。知らない強さの波が繰り返し寄せてきて、その度に爪が男の背に食い込んだ。\n\n終わった後、男は何も聞かずに毛布をかけた。ミーシャは目を開けたまま、しばらく星空を見ていた。夜が明ける前、虎の隣に戻る。毛皮に頬を寄せた。人間の温度とは違う、けれど同じくらい確かな体温だった。"
hp_change = 6

[sub_resource type="Resource" id="choice_2"]
script = ExtResource("2")
label = "虎のそばへ戻る（拒む）"
requirement = ""
result_text = "男の手が伸びてくる前に、椀を置いて立ち上がった。「……ごめん」。それだけ言って、虎の眠る岩陰へ歩いた。虎の耳がぴくりと動き、片目だけ開いてミーシャを見る。すぐに閉じた。安全の合図。毛布を虎の腹に重ね、体温を分けてもらう。振り返らなかった。振り返れば、何かが変わってしまう気がした。"
hp_change = 2

[sub_resource type="Resource" id="choice_3"]
script = ExtResource("2")
label = "傍にいることだけ許す。触れなくていい"
requirement = ""
result_text = "椀を両手で包んだまま、視線だけを男に向けた。「……いていい。でも、触らないで」。声は小さかったが、初めて自分から出した条件だった。男は頷き、少し距離を空けて座り直す。詰めてこない。それだけで、呼吸が少し楽になった。\n\n焚火が爆ぜる音。虎の寝息。男が湯気を吹く音。三つの音が同じ夜に収まっている。支配する側にもされる側にもならない距離が、こんなに落ち着くとは知らなかった。\n\n「ありがとう」。椀を返しながら、初めて言えた言葉だった。男は驚いた顔をして、それから小さく笑う。何も聞かず、何も求めない。それだけのことが、大きな意味を持っていた。"
hp_change = 3
karma_change = 2

[resource]
script = ExtResource("1")
id = &"beast_master_equal_night"
title = "対等の夜"
body_text = "集落の外れ、共同水場の近く。虎は少し離れた岩陰で丸くなっている——昼間仕留めた獲物の血を舐め終え、今は眠りに落ちる寸前だ。焚火の番をしていた男が、湯気の立つ椀をミーシャの前に置いた。「傷の手当て、うまいんだな。動物用の薬草だろ、それ」。男の指先に恐怖の匂いはない。ただの好奇心と、少しの気後れ。ミーシャは目を細め、風上に立つ男の匂いを読んだ。"
required_character = &"beast_master"
required_act = 2
choices = [SubResource("choice_1"), SubResource("choice_2"), SubResource("choice_3")]
