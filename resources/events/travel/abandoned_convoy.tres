[gd_resource type="Resource" script_class="EventData" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/data/event_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/event_choice_data.gd" id="2"]

[sub_resource type="Resource" id="choice_1"]
script = ExtResource("2")
label = "車両を漁る"
requirement = ""
result_text = "錆びた車体の中からまだ使える燃料と部品を見つけた。"
fuel_change = 5
scrap_change = 3

[sub_resource type="Resource" id="choice_2"]
script = ExtResource("2")
label = "慎重に調べる（罠かもしれない）"
requirement = ""
result_text = "やはり罠だった。だが警戒していたおかげで被害は最小限で済んだ。"
fuel_change = 2
hp_change = -3

[sub_resource type="Resource" id="choice_3"]
script = ExtResource("2")
label = "無視して通り過ぎる"
requirement = ""
result_text = "何も起こらなかった。安全を選んだのは正しかったのか。"

[resource]
script = ExtResource("1")
id = &"abandoned_convoy"
title = "放棄された車列"
body_text = "道の脇に数台の車両が放棄されている。積荷がまだ残っているようだが…"
choices = [SubResource("choice_1"), SubResource("choice_2"), SubResource("choice_3")]
