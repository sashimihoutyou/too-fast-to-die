[gd_resource type="Resource" script_class="EventData" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/data/event_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/event_choice_data.gd" id="2"]

[sub_resource type="Resource" id="choice_1"]
script = ExtResource("2")
label = "嵐が過ぎるまで待つ"
requirement = ""
result_text = "長い時間を無駄にしたが、バイクは無傷だ。"
fuel_change = -2

[sub_resource type="Resource" id="choice_2"]
script = ExtResource("2")
label = "燃料を使って強行突破する"
requirement = "fuel>=5"
result_text = "砂嵐の中を突っ切った。バイクの外装が少し傷んだが、時間は稼げた。"
fuel_change = -3
hp_change = -5

[sub_resource type="Resource" id="choice_3"]
script = ExtResource("2")
label = "迂回路を探す"
requirement = ""
result_text = "遠回りしたが、途中で使えそうな物資を見つけた。"
fuel_change = -4
scrap_change = 2

[resource]
script = ExtResource("1")
id = &"dust_storm"
title = "砂嵐"
body_text = "前方に巨大な砂嵐が迫っている。視界はほぼゼロだ。"
character_reactions = {
&"cultist": "砂嵐が迫る。アータルはゴーグルを下ろし、ペンダントを握った。「スピード・デーモンの吐息だ。我々を試している」。エンジンの回転数が上がる。止まるか、突き抜けるか。",
&"ex_raider": "砂嵐。視界ゼロ。ホーネットは舌打ちした。「最悪。……コカトリスの追手がこの中にいたら見えない」。ハンドルを握る手に力が入る。",
&"wanderer": "砂嵐が前方を塞いでいる。ウェズリーは帽子を押さえた。30年間で何度もこいつに出会った。嵐は通り過ぎる。問題は、その間にどれだけ消耗するかだ。",
&"beast_master": "虎が低く唸った。砂嵐を嫌がっている。ミーシャは虎の首に腕を回した。「……大丈夫。一緒に通る」。虎の心拍が早い。ミーシャの心拍も。",
&"hedonist": "「ウッソ、マジかー」。砂嵐が壁のように迫ってくる。ホタルはジュリエットの鞘を抱きしめた。砂がネオンバイアルに入ったら最悪だ。それだけが心配。",
&"conqueror": "砂嵐。覇者は目を細めた。風の匂いを嗅ぐ。砂の粒子が肌を叩く。痛くはない。ただ、前が見えない。覇者は前が見えなくても歩ける。だがバイクは——覇者はバイクに乗らない。水筒を確認した。"
}
choices = [SubResource("choice_1"), SubResource("choice_2"), SubResource("choice_3")]
