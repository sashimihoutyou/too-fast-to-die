[gd_resource type="Resource" script_class="EventData" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/data/event_data.gd" id="1"]
[ext_resource type="Script" path="res://scripts/data/event_choice_data.gd" id="2"]

[sub_resource type="Resource" id="choice_1"]
script = ExtResource("2")
label = "医薬品で手当てする"
requirement = "medicine>=1"
result_text = "彼女は回復すると、お礼にと自分の持っていた物資を分けてくれた。同行を申し出てきた。"
medicine_change = -1
fuel_change = 3
karma_change = 5
companion_id = &"refugee"

[sub_resource type="Resource" id="choice_2"]
script = ExtResource("2")
label = "物資だけ与えて立ち去る"
requirement = ""
result_text = "少しの食料を置いていった。彼女の目に感謝の色が浮かんだ。"
fuel_change = -2
karma_change = 3

[sub_resource type="Resource" id="choice_3"]
script = ExtResource("2")
label = "無視する"
requirement = ""
result_text = "冷たい選択だが、自分が生き延びなければ誰も救えない。"
karma_change = -2

[resource]
script = ExtResource("1")
id = &"wounded_stranger"
title = "負傷した旅人"
body_text = "道端で倒れている女性を見つけた。まだ息はあるが、傷が深い。"
character_reactions = {
&"cultist": "道端に女が倒れている。血が砂に染みこんでいる。アタルパはペンダントを握った。スピード・デーモンの教えでは、止まることは死だ。だがこの女は止まっている。助けるか。通り過ぎるか。教義は明確な答えをくれない。",
&"ex_raider": "道端に倒れた女。傷の深さを一目で判る——ナイフ、たぶん背後から。「ちっ……レイダーの仕業か」。ヴェスパの目が周囲を走った。追手がまだ近くにいるかもしれない。",
&"wanderer": "倒れている女を見つけた。まだ息がある。ウェズリーは帽子を脱いで、膝をついた。30年の旅で何度もこういう場面に出くわしてきた。助けられたこともある。助けられなかったことも。",
&"beast_master": "（……血の匂い）。虎が鼻を鳴らした。ミーシャは女の傍に膝をつく。傷口を見る。獣に噛まれたのではない。人間の仕業だ。ミーシャの目が暗くなった。",
&"hedonist": "「うわ、マジか」。ホタルは足を止めた。道端で女が血を流している。歓楽街でも見たことがある光景だ。見慣れている。見慣れていることが、たぶんおかしい。",
&"conqueror": "倒れている女。覇者は足を止めた。弱い。見ればわかる。覇者は首飾りに触れた。弱い者をどうするか。それが、旅人との約束だった。"
}
choices = [SubResource("choice_1"), SubResource("choice_2"), SubResource("choice_3")]
