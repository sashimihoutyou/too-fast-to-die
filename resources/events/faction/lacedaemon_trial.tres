[sub_resource type="Resource" id="choice_3"]
script = ExtResource("2")
label = "引き返す"
requirement = ""
result_text = "別ルートへ迂回する。"
fuel_change = -2

[resource]
script = ExtResource("1")
id = &"lacedaemon_trial"
title = "戦士の試練"
